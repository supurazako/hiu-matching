{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hiu-matching",
  "compatibility_date": "2026-04-21",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "routes": [
    {
      "pattern": "hiu-matching.supurazako.com",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
